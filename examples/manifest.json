      "spec": "SPEC.md 6.6"
    },
    {
      "path": "examples/invalid/invalid-status.md",
      "command": "rac validate examples/invalid/invalid-status.md",
      "expected": [{ "code": "invalid-decision-status", "severity": "error", "enforcement": "blocking" }],
      "spec": "SPEC.md 7"
    },
    {
